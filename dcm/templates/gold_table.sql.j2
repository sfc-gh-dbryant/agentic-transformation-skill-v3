-- =============================================================================
-- gold_table.sql.j2
-- Template: DEFINE TABLE statement for a Gold table.
-- Used by EXPORT_DCM_PROJECT to generate DCM-compatible definitions.
--
-- Jinja2 variables:
--   {{ database }}     - target database
--   {{ gold_schema }}  - Gold schema name (usually GOLD)
--   {{ table_name }}   - Gold table name
--   {{ columns }}      - list of {name, type, comment} dicts
--   {{ cluster_keys }} - list of clustering key columns
--   {{ source_silver_table }} - fully qualified Silver source
--   {{ export_timestamp }}    - ISO 8601 export timestamp
-- =============================================================================

-- Source Silver: {{ source_silver_table }}
-- Exported: {{ export_timestamp }}
DEFINE TABLE {{ database }}.{{ gold_schema }}.{{ table_name }} (
{% for col in columns %}
    {{ col.name }}  {{ col.type }}{% if col.comment %}  COMMENT '{{ col.comment }}'{% endif %}{% if not loop.last %},{% endif %}

{% endfor %}
)
COMMENT = 'Gold analytical table. Generated by Agentic Transformation Skill. Source: {{ source_silver_table }}.'
{% if cluster_keys %}
CLUSTER BY ({{ cluster_keys | join(', ') }})
{% endif %}
;
